{
  "agent.hostnameAlias": "cleverHost",
  "agent.logging": "info",
  "agent.configFileWatchPeriod": 1,
  "agent.transactionNameSchemes": [
    {
      "scheme": "spanAttribute",
      "delimiter": ":",
      "attributes": [
        "HandlerName",
        "http.request.method",
        "http.method"
      ]
    }
  ],
  "agent.transactionSettings": [
    {
      "regex": ".*/specialties",
      "tracing": "disabled"
    }
  ],
  "profiler": {
    "enabled": true,
    "interval": 10
  }
}
